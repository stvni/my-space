# ─────────────────────────────────────────────────────────────
# My Space — Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or any file containing real keys.
# ─────────────────────────────────────────────────────────────

# Anthropic API — used by PeakCoach and Chat panel
# Get your key at: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# App metadata (optional overrides)
VITE_APP_NAME=My Space
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
